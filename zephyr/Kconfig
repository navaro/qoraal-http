menu "Qoraal-http"

config QORAAL_HTTP
    bool "Enable Qoraal framework"
    default n

if QORAAL_HTTP

config QORAAL_HTTP_SERVER_TLS
    bool "Enable http server"
    select MBEDTLS
    default y

config QORAAL_HTTP_CLIENT_TLS
    bool "Enable http client"
    select MBEDTLS
    default y

config QORAAL_HTTP_SERVER_USER_THREAD
    int "Enable http server user thread"
    default 2

endif # QORAAL_HTTP

endmenu
