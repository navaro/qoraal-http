static const char swagger_ui_index_html[] =
"<!DOCTYPE html>\n"
"<html>\n"
"<head>\n"
"<meta charset=\"utf-8\">\n"
"<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n"
"<title>WebAPI Explorer</title>\n"
"\n"
"<style>\n"
"body {\n"
"    margin: 0;\n"
"    padding: 24px;\n"
"    font-family: Arial, sans-serif;\n"
"    background: #0f172a;\n"
"    color: #e2e8f0;\n"
"}\n"
"\n"
"h1 {\n"
"    margin: 0 0 8px 0;\n"
"    font-size: 28px;\n"
"    color: #f8fafc;\n"
"}\n"
"\n"
".subtitle {\n"
"    margin-bottom: 24px;\n"
"    color: #94a3b8;\n"
"    font-size: 14px;\n"
"}\n"
"\n"
"#endpoints {\n"
"    display: grid;\n"
"    gap: 20px;\n"
"}\n"
"\n"
".endpoint-card {\n"
"    background: #111827;\n"
"    border: 1px solid #334155;\n"
"    border-radius: 14px;\n"
"    padding: 18px;\n"
"    box-shadow: 0 8px 24px rgba(0,0,0,0.25);\n"
"}\n"
"\n"
".endpoint-header {\n"
"    display: flex;\n"
"    justify-content: space-between;\n"
