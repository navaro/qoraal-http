"</style>\n"
"\n"
"<script src=\"swagger-ui.js\"></script>\n"
"\n"
"</head>\n"
"\n"
"<body>\n"
"\n"
"<h1>Device API</h1>\n"
"<div class=\"subtitle\">Interactive WebAPI explorer</div>\n"
"\n"
"<div id=\"endpoints\">\n"
