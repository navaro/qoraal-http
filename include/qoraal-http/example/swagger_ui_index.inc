"}\n"
"\n"
".btn:disabled {\n"
"    opacity: 0.6;\n"
"    cursor: default;\n"
"}\n"
"\n"
".btn-primary {\n"
"    background: #2563eb;\n"
"    color: white;\n"
"}\n"
"\n"
".btn-secondary {\n"
"    background: #334155;\n"
"    color: white;\n"
"}\n"
"\n"
".form {\n"
"    display: grid;\n"
"    gap: 12px;\n"
"    margin-bottom: 16px;\n"
"}\n"
"\n"
".prop-row {\n"
"    display: grid;\n"
"    gap: 6px;\n"
"}\n"
"\n"
".prop-label {\n"
"    font-size: 14px;\n"
"    color: #cbd5e1;\n"
"}\n"
"\n"
".prop-input {\n"
"    width: 100%;\n"
"    box-sizing: border-box;\n"
"    padding: 10px 12px;\n"
"    border-radius: 10px;\n"
"    border: 1px solid #475569;\n"
"    background: #0f172a;\n"
"    color: #f8fafc;\n"
"    font-size: 14px;\n"
"}\n"
"\n"
".prop-input:focus {\n"
"    outline: none;\n"
"    border-color: #60a5fa;\n"
"    box-shadow: 0 0 0 3px rgba(96, 165, 250, 0.15);\n"
"}\n"
".prop-input-readonly {\n"
"    background: #1e293b;\n"
"    color: #94a3b8;\n"
"}\n"
"\n"
".prop-meta {\n"
"    font-size: 12px;\n"
"    color: #94a3b8;\n"
"}\n"
"\n"
".response {\n"
"    margin: 0;\n"
"    padding: 14px;\n"
"    border-radius: 10px;\n"
