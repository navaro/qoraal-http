static const char dashboard_index_html[] =
"<!DOCTYPE html>\n"
"<html lang=\"en\">\n"
"<head>\n"
"<meta charset=\"utf-8\">\n"
"<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">\n"
"<title>Device Dashboard</title>\n"
"<style>\n"
"*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}\n"
":root{\n"
"  --bg:#0f172a;--card:#1e293b;--border:#334155;\n"
"  --text:#e2e8f0;--muted:#64748b;--accent:#7c3aed;\n"
"  --green:#22c55e;--red:#ef4444;--yellow:#f59e0b;\n"
"}\n"
"body{background:var(--bg);color:var(--text);font-family:Arial,sans-serif;min-height:100vh}\n"
"header{\n"
"  background:#111827;border-bottom:1px solid var(--border);\n"
"  padding:16px 28px;display:flex;align-items:center;justify-content:space-between;\n"
"}\n"
"header h1{font-size:18px;font-weight:bold;letter-spacing:.5px}\n"
".live{display:flex;align-items:center;gap:8px;font-size:13px;color:var(--muted)}\n"
".dot{width:9px;height:9px;border-radius:50%;background:var(--yellow);transition:background .4s}\n"
".dot.ok{background:var(--green);box-shadow:0 0 7px var(--green);animation:glow 2.5s infinite}\n"
"@keyframes glow{0%,100%{opacity:1}50%{opacity:.5}}\n"
"main{padding:28px;max-width:1280px;margin:0 auto}\n"
".sec{font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;\n"
"  letter-spacing:1.2px;margin:0 0 14px}\n"
".grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(270px,1fr));\n"
"  gap:18px;margin-bottom:32px}\n"
".card{\n"
"  background:var(--card);border:1px solid var(--border);border-radius:14px;\n"
"  padding:20px;transition:border-color .3s;\n"
"}\n"
".card.updated{border-color:var(--accent)}\n"
".card-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:16px}\n"
".card-name{font-weight:700;font-size:16px;text-transform:capitalize}\n"
".badge{font-size:11px;padding:3px 9px;border-radius:99px;font-weight:600}\n"
".badge-ok{background:#14532d44;color:var(--green);border:1px solid #14532d}\n"
".badge-load{background:#78350f33;color:var(--yellow);border:1px solid #78350f}\n"
".badge-err{background:#7f1d1d33;color:var(--red);border:1px solid #7f1d1d}\n"
".props{display:flex;flex-direction:column}\n"
".prop{display:flex;justify-content:space-between;align-items:baseline;\n"
"  padding:7px 0;border-bottom:1px solid var(--border);font-size:13px}\n"
".prop:last-child{border-bottom:none;padding-bottom:0}\n"
".pk{color:var(--muted)}\n"
".pv{font-weight:600;text-align:right;word-break:break-all;max-width:60%}\n"
".pv-t{color:var(--green)}.pv-f{color:var(--red)}.pv-n{color:var(--muted)}\n"
".feed-wrap{background:var(--card);border:1px solid var(--border);border-radius:14px;overflow:hidden}\n"
".feed-head{\n"
"  padding:14px 20px;border-bottom:1px solid var(--border);\n"
"  display:flex;justify-content:space-between;align-items:center;\n"
"}\n"
".feed-title{font-weight:700;font-size:14px}\n"
".feed-meta{font-size:12px;color:var(--muted)}\n"
".feed-list{max-height:360px;overflow-y:auto}\n"
".ev{\n"
"  display:grid;grid-template-columns:68px 90px 1fr;\n"
"  gap:10px;padding:10px 20px;border-bottom:1px solid #0f172a;\n"
"  font-size:13px;align-items:start;\n"
"}\n"
".ev:last-child{border-bottom:none}\n"
".ev-time{color:var(--muted);font-variant-numeric:tabular-nums;font-size:12px;padding-top:1px}\n"
".ev-src{font-weight:600;text-transform:capitalize;font-size:12px;\n"
"  padding-top:1px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}\n"
".ev-body{}\n"
".ev-kv{display:flex;flex-wrap:wrap;gap:8px}\n"
".ev-pair{\n"
"  display:inline-flex;gap:4px;background:#ffffff0a;\n"
"  border:1px solid var(--border);border-radius:6px;padding:1px 7px;font-size:12px;\n"
"}\n"
".ev-key{color:var(--muted)}.ev-val{color:var(--text);font-weight:500}\n"
".empty-feed{padding:20px;color:var(--muted);font-size:13px;text-align:center}\n"
".card-empty{color:var(--muted);font-size:13px}\n"
"</style>\n"
"</head>\n"
"<body>\n"
"<header>\n"
"  <h1>Device Dashboard</h1>\n"
"  <div class=\"live\">\n"
"    <div class=\"dot\" id=\"dot\"></div>\n"
"    <span id=\"liveLabel\">Connecting</span>\n"
"  </div>\n"
"</header>\n"
"<main>\n"
"  <p class=\"sec\">Modules</p>\n"
"  <div class=\"grid\" id=\"grid\"></div>\n"
"  <p class=\"sec\">Live Events</p>\n"
"  <div class=\"feed-wrap\">\n"
"    <div class=\"feed-head\">\n"
"      <span class=\"feed-title\">Event Stream</span>\n"
"      <span class=\"feed-meta\" id=\"emeta\">waiting...</span>\n"
"    </div>\n"
"    <div class=\"feed-list\" id=\"elist\">\n"
"      <div class=\"empty-feed\">Connecting to event stream...</div>\n"
"    </div>\n"
"  </div>\n"
"</main>\n"
"<script>\n"
"var SKIP={events:1,'openapi.json':1,openapi:1,'swagger-ui':1,rapidoc:1,\n"
"  scalar:1,dashboard:1,'thing-description':1,wot:1};\n"
"var cards={};\n"
"var modNames={};\n"
"var evCount=0;\n"
"\n"
"function ts(){\n"
"  var d=new Date();\n"
"  return ('0'+d.getHours()).slice(-2)+':'+\n"
"         ('0'+d.getMinutes()).slice(-2)+':'+\n"
"         ('0'+d.getSeconds()).slice(-2);\n"
"}\n"
"\n"
"function epName(path){ return path.split('/').pop(); }\n"
"\n"
"function fmtVal(v){\n"
"  if(v===null||v===undefined) return {t:'-',c:'pv-n'};\n"
"  if(typeof v==='boolean')    return {t:v?'true':'false',c:v?'pv-t':'pv-f'};\n"
"  return {t:String(v),c:''};\n"
"}\n"
"\n"
"function makeCard(name,path){\n"
"  var d=document.createElement('div');\n"
"  d.className='card';\n"
"  d.id='card-'+name;\n"
"  d.innerHTML=\n"
"    '<div class=\"card-head\">'+\n"
"      '<span class=\"card-name\">'+name+'</span>'+\n"
"      '<span class=\"badge badge-load\" id=\"b-'+name+'\">Loading</span>'+\n"
"    '</div>'+\n"
"    '<div class=\"props\" id=\"p-'+name+'\"></div>';\n"
"  cards[name]=path;\n"
"  return d;\n"
"}\n"
"\n"
"function fillCard(name,data){\n"
"  var b=document.getElementById('b-'+name);\n"
"  var p=document.getElementById('p-'+name);\n"
"  var c=document.getElementById('card-'+name);\n"
"  if(!b||!p) return;\n"
"  b.className='badge badge-ok'; b.textContent='OK';\n"
"  p.innerHTML='';\n"
"  if(!data||typeof data!=='object'){ p.innerHTML='<span class=\"card-empty\">No data</span>'; return; }\n"
"  var keys=Object.keys(data);\n"
"  if(!keys.length){ p.innerHTML='<span class=\"card-empty\">No properties</span>'; return; }\n"
"  keys.forEach(function(k){\n"
"    var r=fmtVal(data[k]);\n"
"    var row=document.createElement('div');\n"
"    row.className='prop';\n"
"    row.innerHTML='<span class=\"pk\">'+k+'</span><span class=\"pv '+r.c+'\">'+r.t+'</span>';\n"
"    p.appendChild(row);\n"
"  });\n"
"  if(c){ c.classList.add('updated'); setTimeout(function(){ c.classList.remove('updated'); },600); }\n"
"}\n"
"\n"
"function errCard(name){\n"
"  var b=document.getElementById('b-'+name);\n"
"  if(b){ b.className='badge badge-err'; b.textContent='Error'; }\n"
"}\n"
"\n"
"function fetchCard(name){\n"
"  fetch(cards[name])\n"
"    .then(function(r){ return r.json(); })\n"
"    .then(function(d){ fillCard(name,d); })\n"
"    .catch(function(){ errCard(name); });\n"
"}\n"
"\n"
"function addEvent(mod,d){\n"
"  evCount++;\n"
"  var list=document.getElementById('elist');\n"
"  var emp=list.querySelector('.empty-feed');\n"
"  if(emp) list.removeChild(emp);\n"
"  var item=document.createElement('div');\n"
"  item.className='ev';\n"
"  var src=modNames[mod]||('mod '+mod);\n"
"  var kvHtml='';\n"
"  if(d&&typeof d==='object'){\n"
"    kvHtml='<div class=\"ev-kv\">';\n"
"    Object.keys(d).forEach(function(k){\n"
"      kvHtml+='<span class=\"ev-pair\"><span class=\"ev-key\">'+k+'</span>'+\n"
"               '<span class=\"ev-val\">'+String(d[k])+'</span></span>';\n"
"    });\n"
"    kvHtml+='</div>';\n"
"  } else if(d){\n"
"    kvHtml='<span>'+String(d)+'</span>';\n"
"  }\n"
"  item.innerHTML=\n"
"    '<span class=\"ev-time\">'+ts()+'</span>'+\n"
"    '<span class=\"ev-src\">'+src+'</span>'+\n"
"    '<div class=\"ev-body\">'+kvHtml+'</div>';\n"
"  list.insertBefore(item,list.firstChild);\n"
"  while(list.children.length>60) list.removeChild(list.lastChild);\n"
"  document.getElementById('emeta').textContent=evCount+' received';\n"
"  if(modNames[mod]) fetchCard(modNames[mod]);\n"
"}\n"
"\n"
"function setLive(ok){\n"
"  var dot=document.getElementById('dot');\n"
"  var lbl=document.getElementById('liveLabel');\n"
"  if(ok){ dot.className='dot ok'; lbl.textContent='Live'; }\n"
"  else  { dot.className='dot';    lbl.textContent='Reconnecting'; }\n"
"}\n"
"\n"
"function startSSE(){\n"
"  var es=new EventSource('/api/v1/events');\n"
"  es.onopen=function(){ setLive(true); };\n"
"  es.onmessage=function(e){\n"
"    try{ var d=JSON.parse(e.data); addEvent(d.module,d.d); }catch(_){}\n"
"  };\n"
"  es.onerror=function(){ setLive(false); };\n"
"}\n"
"\n"
"function init(){\n"
"  fetch('/api/v1/openapi.json')\n"
"    .then(function(r){ return r.json(); })\n"
"    .then(function(api){\n"
"      var grid=document.getElementById('grid');\n"
"      var modIdx=0;\n"
"      Object.keys(api.paths||{}).forEach(function(p){\n"
"        var n=epName(p);\n"
"        if(SKIP[n]||!api.paths[p].get) return;\n"
"        modNames[modIdx]=n;\n"
"        modIdx++;\n"
"        grid.appendChild(makeCard(n,p));\n"
"        fetchCard(n);\n"
"      });\n"
"      setInterval(function(){ Object.keys(cards).forEach(fetchCard); },30000);\n"
"      startSSE();\n"
"    })\n"
"    .catch(function(e){\n"
"      document.getElementById('grid').innerHTML=\n"
"        '<div style=\"color:var(--red);font-size:13px\">Failed to load device API: '+e+'</div>';\n"
"    });\n"
"}\n"
"\n"
"window.onload=init;\n"
"</script>\n"
"</body>\n"
"</html>\n";
