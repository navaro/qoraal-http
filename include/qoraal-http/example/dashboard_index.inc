"        <span class=\"feed-title\">Replay Query</span>\n"
"        <span class=\"feed-meta\" id=\"rmeta\">idle</span>\n"
"      </div>\n"
"      <div class=\"ev-filter\" id=\"rfilter\"></div>\n"
"      <div class=\"ev-filter\" id=\"rseverity\"></div>\n"
"      <div class=\"replay-controls\">\n"
"        <input class=\"limit-input\" id=\"rlimit\" type=\"number\" min=\"0\" max=\"100\" value=\"20\">\n"
"        <button type=\"button\" class=\"action-btn\" id=\"rsubmit\">Replay</button>\n"
